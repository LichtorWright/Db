namespace Db {

    /// <summary>
    /// Extension methods that bring LINQ-style dot-syntax to List&lt;T&gt;.
    /// list.Where(pred) → std::ranges::copy_if(list, pred) via UFCS dispatch.
    /// The 'this' first parameter marks each method as an extension on List&lt;T&gt;.
    /// </summary>
    public static class Linq {

        // ── Projection ────────────────────────────────────────────────────────

        /// <summary>Projects each element to a new form.</summary>
        [Represents("std::ranges::transform")]
        public static List<TResult> Select<T, TResult>(this List<T> source, Func<T, TResult> selector);

        /// <summary>Projects each element to a list and flattens the results.</summary>
        [Represents("std::ranges::transform")]
        public static List<TResult> SelectMany<T, TResult>(this List<T> source, Func<T, List<TResult>> selector);

        // ── Filtering ─────────────────────────────────────────────────────────

        /// <summary>Returns a new list containing only elements that satisfy predicate.</summary>
        [Represents("std::ranges::copy_if")]
        public static List<T> Where<T>(this List<T> source, Func<T, bool> predicate);

        // ── Element search ────────────────────────────────────────────────────

        /// <summary>Returns the first element matching predicate, or default if none.</summary>
        [Represents("std::ranges::find_if")]
        public static T FirstOrDefault<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>Returns the first element, or default if the list is empty.</summary>
        [Represents("std::ranges::find_if")]
        public static T FirstOrDefault<T>(this List<T> source);

        /// <summary>Returns the first element matching predicate. Throws if none.</summary>
        [Represents("std::ranges::find_if")]
        public static T First<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>Returns the first element. Throws if empty.</summary>
        [Represents("front")]
        public static T First<T>(this List<T> source);

        /// <summary>Returns the last element matching predicate, or default if none.</summary>
        [Represents("std::ranges::find_if")]
        public static T LastOrDefault<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>Returns the last element, or default if empty.</summary>
        [Represents("back")]
        public static T LastOrDefault<T>(this List<T> source);

        /// <summary>Returns the single element matching predicate. Throws if 0 or >1.</summary>
        [Represents("std::ranges::find_if")]
        public static T Single<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>Returns the single element, or default if none. Throws if >1.</summary>
        [Represents("std::ranges::find_if")]
        public static T SingleOrDefault<T>(this List<T> source, Func<T, bool> predicate);

        // ── Quantifiers ───────────────────────────────────────────────────────

        /// <summary>True if any element satisfies predicate.</summary>
        [Represents("std::ranges::any_of")]
        public static bool Any<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>True if the list has at least one element.</summary>
        [Represents("empty")]
        public static bool Any<T>(this List<T> source);

        /// <summary>True if all elements satisfy predicate.</summary>
        [Represents("std::ranges::all_of")]
        public static bool All<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>True if no element satisfies predicate.</summary>
        [Represents("std::ranges::none_of")]
        public static bool None<T>(this List<T> source, Func<T, bool> predicate);

        // ── Counting ──────────────────────────────────────────────────────────

        /// <summary>Returns the number of elements satisfying predicate.</summary>
        [Represents("std::ranges::count_if")]
        public static int Count<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>Returns the total element count.</summary>
        [Represents("size")]
        public static int Count<T>(this List<T> source);

        // ── Aggregation ───────────────────────────────────────────────────────

        /// <summary>Returns the minimum element (comparable T).</summary>
        [Represents("std::ranges::min")]
        public static T Min<T>(this List<T> source);

        /// <summary>Returns the minimum value produced by selector.</summary>
        [Represents("std::ranges::min_element")]
        public static TKey Min<T, TKey>(this List<T> source, Func<T, TKey> selector);

        /// <summary>Returns the maximum element (comparable T).</summary>
        [Represents("std::ranges::max")]
        public static T Max<T>(this List<T> source);

        /// <summary>Returns the maximum value produced by selector.</summary>
        [Represents("std::ranges::max_element")]
        public static TKey Max<T, TKey>(this List<T> source, Func<T, TKey> selector);

        /// <summary>Sums all elements (addable T).</summary>
        [Represents("std::accumulate")]
        public static T Sum<T>(this List<T> source);

        /// <summary>Sums values produced by selector.</summary>
        [Represents("std::accumulate")]
        public static TKey Sum<T, TKey>(this List<T> source, Func<T, TKey> selector);

        /// <summary>Arithmetic mean of elements (numeric T).</summary>
        [Represents("std::accumulate")]
        public static double Average<T>(this List<T> source);

        /// <summary>Mean of values produced by selector.</summary>
        [Represents("std::accumulate")]
        public static double Average<T, TKey>(this List<T> source, Func<T, TKey> selector);

        /// <summary>Reduces with a seed and an accumulator function.</summary>
        [Represents("std::accumulate")]
        public static TAccum Aggregate<T, TAccum>(this List<T> source, TAccum seed, Func<TAccum, T, TAccum> accumulator);

        // ── Ordering ──────────────────────────────────────────────────────────

        /// <summary>Returns a new list sorted in ascending order by key.</summary>
        [Represents("std::ranges::sort")]
        public static List<T> OrderBy<T, TKey>(this List<T> source, Func<T, TKey> keySelector);

        /// <summary>Returns a new list sorted in descending order by key.</summary>
        [Represents("std::ranges::sort")]
        public static List<T> OrderByDescending<T, TKey>(this List<T> source, Func<T, TKey> keySelector);

        /// <summary>Secondary ascending sort (stable).</summary>
        [Represents("std::ranges::stable_sort")]
        public static List<T> ThenBy<T, TKey>(this List<T> source, Func<T, TKey> keySelector);

        /// <summary>Secondary descending sort (stable).</summary>
        [Represents("std::ranges::stable_sort")]
        public static List<T> ThenByDescending<T, TKey>(this List<T> source, Func<T, TKey> keySelector);

        /// <summary>Returns a reversed copy of the list.</summary>
        [Represents("std::ranges::reverse")]
        public static List<T> Reverse<T>(this List<T> source);

        // ── Partitioning ──────────────────────────────────────────────────────

        /// <summary>Returns the first n elements.</summary>
        [Represents("std::ranges::take")]
        public static List<T> Take<T>(this List<T> source, int count);

        /// <summary>Returns elements while predicate is true.</summary>
        [Represents("std::ranges::take_while")]
        public static List<T> TakeWhile<T>(this List<T> source, Func<T, bool> predicate);

        /// <summary>Skips the first n elements.</summary>
        [Represents("std::ranges::drop")]
        public static List<T> Skip<T>(this List<T> source, int count);

        /// <summary>Skips elements while predicate is true, returns the rest.</summary>
        [Represents("std::ranges::drop_while")]
        public static List<T> SkipWhile<T>(this List<T> source, Func<T, bool> predicate);

        // ── Set operations ────────────────────────────────────────────────────

        /// <summary>Returns distinct elements (duplicates removed).</summary>
        [Represents("std::unique")]
        public static List<T> Distinct<T>(this List<T> source);

        /// <summary>Returns elements distinct by key selector.</summary>
        [Represents("std::unique")]
        public static List<T> DistinctBy<T, TKey>(this List<T> source, Func<T, TKey> keySelector);

        /// <summary>Elements also present in other.</summary>
        [Represents("std::set_intersection")]
        public static List<T> Intersect<T>(this List<T> source, List<T> other);

        /// <summary>Elements not present in other.</summary>
        [Represents("std::set_difference")]
        public static List<T> Except<T>(this List<T> source, List<T> other);

        /// <summary>Concatenates two lists.</summary>
        [Represents("std::ranges::copy")]
        public static List<T> Concat<T>(this List<T> source, List<T> other);

        // ── Grouping ──────────────────────────────────────────────────────────

        /// <summary>Groups elements by key; returns a dictionary of key → list.</summary>
        [Represents("std::unordered_map")]
        public static Dict<TKey, List<T>> GroupBy<T, TKey>(this List<T> source, Func<T, TKey> keySelector);

        // ── Conversion ────────────────────────────────────────────────────────

        /// <summary>Returns a copy as a new List.</summary>
        [Represents("std::vector")]
        public static List<T> ToList<T>(this List<T> source);

        /// <summary>Builds a dictionary keyed by keySelector. Throws on duplicate keys.</summary>
        [Represents("std::unordered_map")]
        public static Dict<TKey, T> ToDictionary<T, TKey>(this List<T> source, Func<T, TKey> keySelector);

        /// <summary>Builds a dictionary with separate key and value selectors.</summary>
        [Represents("std::unordered_map")]
        public static Dict<TKey, TValue> ToDictionary<T, TKey, TValue>(this List<T> source, Func<T, TKey> keySelector, Func<T, TValue> valueSelector);

        /// <summary>Converts to a Set (removes duplicates).</summary>
        [Represents("std::unordered_set")]
        public static Set<T> ToSet<T>(this List<T> source);

        // ── Joining ───────────────────────────────────────────────────────────

        /// <summary>Joins two sequences on matching keys.</summary>
        [Represents("std::ranges::transform")]
        public static List<TResult> Join<TOuter, TInner, TKey, TResult>(
            this List<TOuter> source,
            List<TInner> inner,
            Func<TOuter, TKey> outerKeySelector,
            Func<TInner, TKey> innerKeySelector,
            Func<TOuter, TInner, TResult> resultSelector);

        // ── Index access ──────────────────────────────────────────────────────

        /// <summary>Returns element at index, or default if out of range.</summary>
        [Represents("at")]
        public static T ElementAtOrDefault<T>(this List<T> source, int index);

        // ── Containment ───────────────────────────────────────────────────────

        /// <summary>True if source contains item (equality).</summary>
        [Represents("std::ranges::contains")]
        public static bool Contains<T>(this List<T> source, T item);

        // ── String joining ────────────────────────────────────────────────────

        /// <summary>Concatenates string representations of all elements with a separator.</summary>
        [Represents("std::accumulate")]
        public static string StringJoin<T>(this List<T> source, string separator);
    }
}